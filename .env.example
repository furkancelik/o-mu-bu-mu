# MongoDB bağlantısı — yayında MongoDB Atlas connection string'i
# Lokalde: mongodb://127.0.0.1:27017/omubumu
# Atlas: mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/omubumu
MONGODB_URI=mongodb://127.0.0.1:27017/omubumu

# Uygulama adı
NEXT_PUBLIC_APP_NAME=O mu bu mu

# Admin parolası — /admin sayfalarına girmek için
# Yayında en az 24 karakterlik güçlü bir parola seç
ADMIN_PASSWORD=change-me

# Cookie/JWT imzalama anahtarı — `openssl rand -hex 32` ile üret
AUTH_SECRET=change-me-min-32-chars

# Cloudinary kimlik bilgileri — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
